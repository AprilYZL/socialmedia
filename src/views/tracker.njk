{% extends "layout.njk" %}
{% block title %}Tracker{% endblock %}
{% block content %}
<h1>Cross-platform tracker</h1>

{% if pieces.length %}
<div class="table-scroll">
<table class="tracker-table">
  <thead>
    <tr>
      <th>Content</th>
      <th>Type</th>
      {% for p in platforms %}<th>{{ p.display_name }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for piece in pieces %}
    {% set acct = accountsById[piece.account_id] %}
    <tr>
      <td>
        <a href="/piece/{{ piece.id }}">{{ piece.title }}</a>
        {% if activeAccount == 'all' and acct %}
          <span class="badge badge-account" style="--acct: {{ acct.color }}">{{ acct.display_name }}</span>
        {% endif %}
      </td>
      <td class="muted">{{ piece.content_type | replace("_", " ") }}</td>
      {% for p in platforms %}
        {% set v = byPiece[piece.id][p.id] if byPiece[piece.id] else null %}
        <td>
          {% if v %}
            <span class="badge status-{{ v.status }}">{{ v.status }}</span>
            {% if v.live_url %}<a href="{{ v.live_url }}" target="_blank" title="open live post">🔗</a>{% endif %}
          {% elif not enabledMap[piece.account_id][p.id] %}
            <span class="muted" title="{{ p.display_name }} is disabled for {{ acct.display_name }}">·</span>
          {% else %}
            <span class="muted">—</span>
          {% endif %}
        </td>
      {% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% else %}
<p class="muted">No content yet. <a href="/library">Create your first piece in the Library →</a></p>
{% endif %}
{% endblock %}
