{% extends "layout.njk" %}
{% block title %}Calendar{% endblock %}
{% block content %}
<h1>Posting calendar</h1>

<section class="card">
  <h2>Mark a post as published</h2>
  <form method="post" action="/calendar/mark" class="row wrap">
    <select name="piece_id" id="mark-piece" required class="grow">
      <option value="">— pick content —</option>
      {% for p in markPieces %}
      <option value="{{ p.id }}">{{ p.title }}</option>
      {% endfor %}
    </select>
    <select name="platform_id" id="mark-platform" required disabled>
      <option value="">— platform —</option>
    </select>
    <input type="date" name="posted_date" value="{{ prefillDate }}" required>
    <input name="live_url" placeholder="live post URL (optional)">
    <button class="btn-primary">Mark posted</button>
  </form>
  <script id="mark-data" type="application/json">{{ platformsByPiece | dump | safe }}</script>
  <p class="muted small">Records that a piece went live on a platform on that date — same as setting the status to “posted” on the piece page. Tip: click a day number below to pick its date.</p>
</section>

<div class="cal-header">
  <a href="/calendar?month={{ prev }}">← {{ prev }}</a>
  <h2>{{ monthLabel }}</h2>
  <a href="/calendar?month={{ next }}">{{ next }} →</a>
</div>

<div class="table-scroll">
<table class="calendar">
  <thead><tr><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th></tr></thead>
  <tbody>
    {% for week in weeks %}
    <tr>
      {% for day in week %}
      <td class="{% if day == today %}cal-today{% endif %}">
        {% if day %}
        <div class="cal-day"><a href="/calendar?month={{ monthLabel }}&date={{ day }}" title="mark a post published on {{ day }}">{{ day.slice(8) }}</a></div>
        {% for post in postsByDate[day] %}
        {% set acct = accountsById[post.account_id] %}
        <div class="cal-slot">
          {% if acct %}<span class="acct-dot" style="--acct: {{ acct.color }}" title="{{ acct.display_name }}"></span>{% endif %}
          <a href="/piece/{{ post.piece_id }}">{{ post.piece_title | truncate(18) }}</a>
          <span class="muted small">{{ post.platform_name }}</span>
          {% if post.live_url %}<a href="{{ post.live_url }}" target="_blank" rel="noopener" title="open live post">🔗</a>{% endif %}
          <form class="inline" method="post" action="/calendar/unmark/{{ post.variant_id }}" onsubmit="return confirm('Un-mark this post? The variant goes back to “ready”.')">
            <button class="btn-tiny" title="un-mark posted">✕</button>
          </form>
        </div>
        {% endfor %}
        {% endif %}
      </td>
      {% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endblock %}
