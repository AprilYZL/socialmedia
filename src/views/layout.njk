<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Promoter{% endblock %} · Promoter</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <nav class="nav">
    <span class="brand">🎧 Promoter</span>
    <a href="/">Tracker</a>
    <a href="/library">Library</a>
    <a href="/calendar">Calendar</a>
    <a href="/settings">Settings</a>
    <span class="switcher">
      {% for a in accounts %}
        <form method="post" action="/account/{{ a.id }}" class="inline">
          <button class="btn-switch{% if activeAccount == a.id %} active{% endif %}" style="--acct: {{ a.color }}">{{ a.display_name }}</button>
        </form>
      {% endfor %}
      <form method="post" action="/account/all" class="inline">
        <button class="btn-switch{% if activeAccount == 'all' %} active{% endif %}">All</button>
      </form>
    </span>
  </nav>

  <main class="container">
    {% if msg %}<div class="flash flash-ok">{{ msg }}</div>{% endif %}
    {% if err %}<div class="flash flash-err">{{ err }}</div>{% endif %}
    {% block content %}{% endblock %}
  </main>

  <script src="/static/app.js"></script>
</body>
</html>
